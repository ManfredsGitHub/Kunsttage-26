# Produktions-Umgebungsvariablen — Kunsttage auf der Ludwigshöhe 2026
# =====================================================================
# ANLEITUNG:
# 1. Diese Datei auf dem Server nach /var/kunsttage/app/backend/.env kopieren
# 2. Alle Platzhalter <...> ersetzen
# 3. sudo systemctl restart kunsttage-backend

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=<langer-zufaelliger-string-min-32-zeichen>
ADMIN_PASSWORT=<sicheres-passwort-min-10-zeichen>
ORGA_PASSWORT=<sicheres-passwort-min-10-zeichen>

# ── Datenbank ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////var/kunsttage/app/backend/data/kunsttage.db
UPLOAD_DIR=./uploads

# ── URLs — KEIN Port, KEIN trailing slash ─────────────────────────────
BASE_URL=https://kunsttage-ludwigshoehe.de
CORS_ORIGINS=https://kunsttage-ludwigshoehe.de,https://www.kunsttage-ludwigshoehe.de

# ── E-Mail (IONOS SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=info@kunsttage-ludwigshoehe.de
SMTP_PASS=<smtp-passwort>
ADMIN_EMAIL=elmanfred@icloud.com,fh@hammann-hassloch.de

# ── KI (Anthropic) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<api-key-von-console.anthropic.com>
